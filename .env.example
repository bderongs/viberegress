# Copy to .env and fill in your key
# Stagehand supports both — pick one

ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

PORT=3000

# Supabase Auth (email + Google). See SUPABASE_SETUP.md
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase Postgres connection string (server-side only, never expose to browser).
# Example: postgresql://postgres.<ref>:<password>@aws-0-...pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://...
